{
  "manifest_version": 3,
  "name": "Refine It!",
  "version": "1.0",
  "description": "AI-powered text rewriting on any website. Highlight text, pick a style, and it rewrites in place. Supports OpenRouter, ChatGPT, and Gemini. By Mayas Ötegen",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Refine It!",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["onboarding.html", "onboarding.css", "onboarding.js", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
